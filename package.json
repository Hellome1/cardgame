{
  "name": "card-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:dev:win": "set NODE_ENV=development && electron .",
    "electron:preview": "electron .",
    "electron:preview:win": "set NODE_ENV=production && electron .",
    "electron:build": "npm run build && electron-builder",
    "dist": "electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^26.0.0",
    "electron-builder": "^24.6.0",
    "typescript": "^5.0.2",
    "vite": "^4.3.0"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.cardgame.app",
    "productName": "三国卡牌",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}